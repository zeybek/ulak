(1 row)

-- Invalid options type
SELECT ulak.validate_endpoint_config(
    'nats',
    '{"url": "nats://localhost:4222", "subject": "test", "options": "bad"}'::jsonb
) AS invalid_options_type;
WARNING:  [ulak] ERROR: NATS 'options' must be an object
