SELECT circuit_failure_count, circuit_state = 'closed' AS cb_still_closed
FROM ulak.endpoints
WHERE name = 'cb_test_endpoint';
 circuit_failure_count | cb_still_closed 
-----------------------+-----------------
                     3 | t
(1 row)

